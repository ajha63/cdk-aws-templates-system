{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["engine", "instance_class", "vpc_ref"],
  "properties": {
    "engine": {
      "type": "string",
      "enum": ["postgres", "mysql", "mariadb", "oracle-se2", "sqlserver-ex", "sqlserver-web", "sqlserver-se", "sqlserver-ee"],
      "description": "Database engine type"
    },
    "engine_version": {
      "type": "string",
      "description": "Database engine version"
    },
    "instance_class": {
      "type": "string",
      "pattern": "^db\\.[a-z0-9]+\\.[a-z0-9]+$",
      "description": "RDS instance class (e.g., db.t3.medium)"
    },
    "allocated_storage": {
      "type": "integer",
      "minimum": 20,
      "maximum": 65536,
      "default": 100,
      "description": "Allocated storage in GB"
    },
    "multi_az": {
      "type": "boolean",
      "default": false,
      "description": "Enable Multi-AZ deployment"
    },
    "vpc_ref": {
      "type": "string",
      "description": "Reference to VPC resource"
    },
    "subnet_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "References to private subnets"
    },
    "backup_retention_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 35,
      "default": 7,
      "description": "Number of days to retain automated backups"
    },
    "preferred_backup_window": {
      "type": "string",
      "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]-([0-1][0-9]|2[0-3]):[0-5][0-9]$",
      "description": "Preferred backup window (e.g., 03:00-04:00)"
    },
    "encryption_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Enable encryption at rest"
    },
    "storage_encrypted": {
      "type": "boolean",
      "default": true,
      "description": "Enable storage encryption"
    }
  }
}
